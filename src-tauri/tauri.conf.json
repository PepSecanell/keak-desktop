{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keak",
  "version": "0.2.7",
  "identifier": "com.keoly.keak",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "connect",
        "title": "Keak — Connect your AI",
        "url": "/?view=connect",
        "width": 1180,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "maximized": true,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "Keak",
        "url": "/?view=overlay",
        "width": 560,
        "height": 440,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "center": true
      },
      {
        "label": "agents",
        "title": "Keak Agents",
        "url": "/?view=agents",
        "width": 1920,
        "height": 1080,
        "x": 0,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["keak"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp"
      }
    }
  }
}
